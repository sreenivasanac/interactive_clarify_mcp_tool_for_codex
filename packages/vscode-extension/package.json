{
  "name": "interactive-clarify-vscode",
  "displayName": "Interactive Clarify",
  "description": "Structured clarifying-question panel for MCP-based AI coding agents in VS Code",
  "version": "0.1.0",
  "publisher": "interactive-clarify",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sreenivasanac/interactive_clarify_mcp_tool_for_codex.git"
  },
  "homepage": "https://github.com/sreenivasanac/interactive_clarify_mcp_tool_for_codex#readme",
  "bugs": {
    "url": "https://github.com/sreenivasanac/interactive_clarify_mcp_tool_for_codex/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "coding-agent",
    "clarifying-questions",
    "codex",
    "claude-code",
    "webview"
  ],
  "categories": [
    "Machine Learning",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:interactiveClarify.showPanel",
    "onCommand:interactiveClarify.showOutput",
    "onCommand:interactiveClarify.openLateResponsesFolder"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "interactiveClarify.showPanel",
        "category": "Interactive Clarify",
        "title": "Show Questions Panel"
      },
      {
        "command": "interactiveClarify.showOutput",
        "category": "Interactive Clarify",
        "title": "Show Output Log"
      },
      {
        "command": "interactiveClarify.openLateResponsesFolder",
        "category": "Interactive Clarify",
        "title": "Open Late Responses Folder"
      }
    ]
  },
  "scripts": {
    "build:webview": "esbuild src/webview/panel/index.tsx --bundle --outfile=webview-dist/panel.js --format=iife --target=es2020 --loader:.css=css --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --format=cjs --platform=node --external:vscode",
    "build": "pnpm run build:webview && pnpm run build:extension",
    "dev": "pnpm run build",
    "package": "pnpm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "@interactive-clarify/shared": "workspace:*"
  },
  "devDependencies": {
    "@markdown-ui/marked-ext": "^1.4.0",
    "@markdown-ui/react": "^0.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "marked": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0"
  }
}
